# Скопируй этот файл в .env и заполни ключ OpenAI.
# Без ключа сервис работает в МОК-режиме (отчёт-заглушка) — для локальной проверки потока.

# Ключ OpenAI (оценка уровня GPT + расшифровка аудио Whisper). Один ключ на всё.
OPENAI_API_KEY=

# Модели (по умолчанию подходят, можно не менять)
EVAL_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# CORS (через запятую). По умолчанию * — для локальной разработки.
CORS_ORIGINS=*
